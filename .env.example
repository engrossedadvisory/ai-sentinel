# AI Governance Platform — Multi-Brain Configuration
# Copy to .env and fill in your values.
#
# Architecture: 5 specialized brains, each independently configurable.
# Each brain can use a different provider AND a different model.
#
# Providers:  none | claude | ollama | openai
# Claude models:  claude-sonnet-4-6 | claude-opus-4-7 | claude-haiku-4-5-20251001
# Ollama models:  llama3.2 | mistral | phi3 | gemma2 | deepseek-r1 (any pulled model)
# OpenAI models:  gpt-4o | gpt-4o-mini | gpt-4-turbo

# ── API keys ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OLLAMA_HOST=http://localhost:11434   # or http://ollama:11434 inside Docker

# ── Shared fallback (used when per-brain vars are not set) ────────────────
AI_PROVIDER=none
AI_MODEL=

# ═══════════════════════════════════════════════════════════════════════════
# Per-brain overrides — leave blank to inherit AI_PROVIDER / AI_MODEL above
# ═══════════════════════════════════════════════════════════════════════════

# ◇ Triage Brain — routes events, fast classification
#   Recommended: Haiku (fast) or a small local model
BRAIN_TRIAGE_PROVIDER=claude
BRAIN_TRIAGE_MODEL=claude-haiku-4-5-20251001

# ◉ Detection Brain — deep threat analysis of new deployments
#   Recommended: Sonnet (accuracy) or Opus (maximum depth)
BRAIN_DETECTION_PROVIDER=claude
BRAIN_DETECTION_MODEL=claude-sonnet-4-6

# △ Risk Brain — activity risk scoring (called on every event)
#   Recommended: local Ollama (speed, cost) or Sonnet (accuracy)
BRAIN_RISK_PROVIDER=ollama
BRAIN_RISK_MODEL=llama3.2

# ▣ Policy Brain — governance gap analysis, policy drafting
#   Recommended: Sonnet or Opus (reasoning depth matters)
BRAIN_POLICY_PROVIDER=claude
BRAIN_POLICY_MODEL=claude-sonnet-4-6

# ⊛ Mitigation Brain — incident response decisions (critical path)
#   Recommended: Opus (highest accuracy for high-stakes decisions)
BRAIN_MITIGATION_PROVIDER=claude
BRAIN_MITIGATION_MODEL=claude-opus-4-7

# ── Example: fully local / air-gapped config ──────────────────────────────
# AI_PROVIDER=ollama
# OLLAMA_HOST=http://ollama:11434
# BRAIN_TRIAGE_MODEL=phi3
# BRAIN_DETECTION_MODEL=llama3.1
# BRAIN_RISK_MODEL=llama3.2
# BRAIN_POLICY_MODEL=mistral
# BRAIN_MITIGATION_MODEL=llama3.1:70b
